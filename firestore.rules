rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is an admin
    function isAdmin() {
      return request.auth.token.email.matches('.*@perenti\\.com') || 
             request.auth.token.email.matches('.*@ebc\\.com') ||
             request.auth.token.email == 'sreemadhav@gmail.com' ||
             request.auth.token.email == 'shiva24.santosh@gmail.com';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated(); // Anyone logged in can view directories
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Events (Meetups) Collection
    match /events/{eventId} {
      allow read: if true; // Public can see events (e.g. for landing page/discover)
      allow write: if isAuthenticated() && isAdmin();
    }

    // Tickets Collection
    match /tickets/{ticketId} {
      // Admins can read all tickets, users can read their own tickets
      allow read: if isAuthenticated() && (isAdmin() || resource.data.user_email == request.auth.token.email);
      // Only users can create tickets for themselves (registration)
      allow create: if isAuthenticated() && request.resource.data.user_email == request.auth.token.email;
      // Only admins can update (e.g. approve/reject/scan) or users can cancel their own
      allow update, delete: if isAuthenticated() && (isAdmin() || resource.data.user_email == request.auth.token.email);
    }
  }
}
